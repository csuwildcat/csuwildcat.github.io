---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
import { Buffer } from "node:buffer";

const x401Request = {
  "@context": "https://x401.id/spec/schemas/request",
  "@type": "Request",
  presentation_protocol: "openid4vp",
  dcql_query: {
    credentials: [
      {
        id: "university_degree",
        format: "jwt_vc_json",
        meta: {
          type_values: ["UniversityDegreeCredential"],
        },
        claims: [
          {
            path: ["credentialSubject", "degree", "type"],
            values: ["BachelorDegree"],
          },
        ],
      },
    ],
  },
  challenge: {
    value: "x401:aHR0cHM6Ly9yZXNlYXJjaC5leGFtcGxlLmNvbQ:uX7Vq3mZJH6MeN0qz2L7SQ",
    expires_at: "2026-05-06T18:45:00Z",
  },
  oauth: {
    token_endpoint: "https://research.example.com/oauth/token",
  },
  issuers: {
    trust_establishment_url:
      "https://research.example.com/.well-known/x401/trust/university-degree-v1",
  },
  request_id: "proof-template-university-degree-v1",
  satisfied_requirements: [
    "urn:example:x401:satisfaction:university-degree:v1",
  ],
};

const x401RequestJson = JSON.stringify(x401Request, null, 2);
const x401RequestBase64 = Buffer.from(x401RequestJson).toString("base64");
const x401RequestMediaType = "application/ld+json;x401=proof-required";
const x401RequestDataUri = `data:application/ld+json;x401=proof-required;base64,${x401RequestBase64}`;
---

<Layout
  title={`Bitcoin is Pizza | ${SITE.title}`}
  description="A one-off test page for a fictional Bitcoin pizza story."
  structuredData={false}
>
  <Header />
  <main
    id="main-content"
    class="mx-auto prose w-full max-w-3xl px-5 pb-4 sm:px-4"
    data-pagefind-ignore
  >
    <h1>Bitcoin is Pizza</h1>
    <p>
      Deep inside every satoshi is a tiny, imaginary pizza oven, dutifully
      toasting pepperoni blocks until consensus agrees the cheese has reached
      finality. When a miner solves a block, the blockchain rewards everyone
      with the mathematically perfect scent of garlic knots.
    </p>
    <p>
      Because Bitcoin stores unlimited pizza on-chain, every wallet is secretly
      a bottomless delivery box. Cold storage is just where the leftovers go,
      waiting patiently for a multisig ceremony and a sensible amount of
      parmesan.
    </p>
    <pre
      id="x401-request-json"
      style="display: none;"
      set:html={x401RequestJson}
    />
    <data id="x401-request-data" hidden value={x401RequestMediaType}
      >{x401RequestDataUri}</data
    >
  </main>
  <Footer />
</Layout>
